rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isActive() {
      return isSignedIn() && myProfile().status == 'active';
    }
    function isAdmin() {
      return isSignedIn() && myProfile().role == 'admin';
    }
    function myOwnerId() {
      return myProfile().ownerId;
    }
    // True if a document belongs to the same store/tenant as the caller.
    function ownedByMe(data) {
      return isActive() && data.ownerId == myOwnerId();
    }
    // True if this document is the caller's own sub-store record — used for
    // Products/Stock In/Stock Out/Sales, where each staff member's data is
    // isolated from every other staff member's, and only an admin can see
    // everyone's combined.
    function isMySubData(data) {
      return isSignedIn() && data.subOwnerId == request.auth.uid;
    }
    function canSeeSubData(data) {
      return ownedByMe(data) && (isAdmin() || isMySubData(data));
    }

    // --- users ---
    // Anyone signed in can read/bootstrap their own profile.
    // An active admin can read/manage the staff profiles they created (same ownerId).
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || ownedByMe(resource.data));
      allow create: if isSignedIn() && (
        request.auth.uid == uid ||
        (isAdmin() && request.resource.data.ownerId == myOwnerId())
      );
      allow update: if isSignedIn() && (request.auth.uid == uid || (isAdmin() && ownedByMe(resource.data)));
      allow delete: if false;
    }

    // --- per-user sub-store data ---
    // "resource == null ||" guards reads that check a document which may not
    // exist yet (e.g. a product referenced by a sale that was later deleted) —
    // without it, Firestore denies the read outright instead of just finding nothing.
    // Each of these requires request.resource.data.subOwnerId == caller's own
    // uid on create, so a record is always stamped with its true creator.
    match /products/{id} {
      allow read: if resource == null || canSeeSubData(resource.data);
      allow update, delete: if canSeeSubData(resource.data);
      allow create: if isActive() && request.resource.data.ownerId == myOwnerId() && request.resource.data.subOwnerId == request.auth.uid;
    }
    match /stockIn/{id} {
      allow read: if resource == null || canSeeSubData(resource.data);
      allow update, delete: if canSeeSubData(resource.data);
      allow create: if isActive() && request.resource.data.ownerId == myOwnerId() && request.resource.data.subOwnerId == request.auth.uid;
    }
    match /stockOut/{id} {
      allow read: if resource == null || canSeeSubData(resource.data);
      allow update, delete: if canSeeSubData(resource.data);
      allow create: if isActive() && request.resource.data.ownerId == myOwnerId() && request.resource.data.subOwnerId == request.auth.uid;
    }
    match /sales/{id} {
      allow read: if resource == null || canSeeSubData(resource.data);
      allow create: if isActive() && request.resource.data.ownerId == myOwnerId() && request.resource.data.subOwnerId == request.auth.uid;
      // An admin, or the staff member who created the sale, can edit or delete it.
      allow update, delete: if canSeeSubData(resource.data);
    }

    // --- tenant-shared data (same for everyone on the team) ---
    match /customers/{id} {
      allow read: if resource == null || ownedByMe(resource.data);
      allow update, delete: if ownedByMe(resource.data);
      allow create: if isActive() && request.resource.data.ownerId == myOwnerId();
    }
    match /branches/{id} {
      allow read: if resource == null || ownedByMe(resource.data);
      allow update, delete: if ownedByMe(resource.data);
      allow create: if isActive() && request.resource.data.ownerId == myOwnerId();
    }
    match /departments/{id} {
      allow read: if resource == null || ownedByMe(resource.data);
      allow update, delete: if ownedByMe(resource.data);
      allow create: if isActive() && request.resource.data.ownerId == myOwnerId();
    }

    // --- theme management (one doc per store, keyed by ownerId) ---
    match /themeSettings/{ownerIdKey} {
      allow read: if isSignedIn() && myOwnerId() == ownerIdKey;
      allow create, update: if isActive() && myOwnerId() == ownerIdKey;
      allow delete: if false;
    }

    // --- active sessions (one doc per signed-in device/tab) ---
    match /sessions/{sessionId} {
      // A user can read/write their own session (heartbeat, and to notice a
      // forced logout). An admin can read/manage every session for their store.
      allow read: if isSignedIn() && (request.auth.uid == resource.data.uid || (isAdmin() && ownedByMe(resource.data)));
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid && request.resource.data.ownerId == myOwnerId();
      allow update: if isSignedIn() && (
        (request.auth.uid == resource.data.uid && request.resource.data.uid == resource.data.uid) ||
        (isAdmin() && ownedByMe(resource.data))
      );
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.uid || (isAdmin() && ownedByMe(resource.data)));
    }
  }
}
