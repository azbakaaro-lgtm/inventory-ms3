rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isActive() {
      return isSignedIn() && myProfile().status == 'active';
    }
    function isAdmin() {
      return isSignedIn() && myProfile().role == 'admin';
    }
    function myOwnerId() {
      return myProfile().ownerId;
    }
    // True if a document belongs to the same store/tenant as the caller.
    function ownedByMe(data) {
      return isActive() && data.ownerId == myOwnerId();
    }

    // --- users ---
    // Anyone signed in can read/bootstrap their own profile.
    // An active admin can read/manage the staff profiles they created (same ownerId).
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || ownedByMe(resource.data));
      allow create: if isSignedIn() && (
        request.auth.uid == uid ||
        (isAdmin() && request.resource.data.ownerId == myOwnerId())
      );
      allow update: if isSignedIn() && (request.auth.uid == uid || (isAdmin() && ownedByMe(resource.data)));
      allow delete: if false;
    }

    // --- tenant-scoped store data ---
    match /products/{id} {
      allow read, update, delete: if ownedByMe(resource.data);
      allow create: if isActive() && request.resource.data.ownerId == myOwnerId();
    }
    match /stockIn/{id} {
      allow read, update, delete: if ownedByMe(resource.data);
      allow create: if isActive() && request.resource.data.ownerId == myOwnerId();
    }
    match /stockOut/{id} {
      allow read, update, delete: if ownedByMe(resource.data);
      allow create: if isActive() && request.resource.data.ownerId == myOwnerId();
    }
    match /sales/{id} {
      allow read, update, delete: if ownedByMe(resource.data);
      allow create: if isActive() && request.resource.data.ownerId == myOwnerId();
    }
    match /customers/{id} {
      allow read, update, delete: if ownedByMe(resource.data);
      allow create: if isActive() && request.resource.data.ownerId == myOwnerId();
    }
    match /branches/{id} {
      allow read, update, delete: if ownedByMe(resource.data);
      allow create: if isActive() && request.resource.data.ownerId == myOwnerId();
    }
    match /departments/{id} {
      allow read, update, delete: if ownedByMe(resource.data);
      allow create: if isActive() && request.resource.data.ownerId == myOwnerId();
    }
  }
}
